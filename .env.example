# MiMo V2.5 Open Platform
# 申请通过后填入 https://platform.xiaomimimo.com 颁发的 key
MIMO_API_KEY=

# 默认指向 MiMo 公开 API 网关
MIMO_BASE_URL=https://api.xiaomimimo.com

# 模型 ID（可被 lib/mimo.ts 中的常量覆盖）
MIMO_MODEL_REASON=mimo-v2.5-reason
MIMO_MODEL_VISION=mimo-v2.5-vision
MIMO_MODEL_TTS=mimo-v2.5-tts

# 主播音色 ID
MIMO_VOICE_HOST=mimo_lin_zh_warm
MIMO_VOICE_GUEST=mimo_wei_zh_natural

# 本地开发开关：true 时 lib/mimo.ts 跳过真实调用，返回 mock 数据
# 建议在没有 API key 时保持 true，避免产生计费
MIMO_USE_MOCK=true
