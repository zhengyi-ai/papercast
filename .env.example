# LLM API 配置
# 填入你使用的模型供应商 API key
LLM_API_KEY=

# API 网关地址（OpenAI 兼容格式）
LLM_BASE_URL=https://api.example.com

# 模型 ID（推理 / 文生图 / 语音合成三种能力）
LLM_MODEL_REASON=reason-model
LLM_MODEL_VISION=vision-model
LLM_MODEL_TTS=tts-model

# 主播音色 ID
LLM_VOICE_HOST=voice-host-female
LLM_VOICE_GUEST=voice-guest-male

# 本地开发开关：true 时跳过真实调用，返回 mock 数据
LLM_USE_MOCK=true
